<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:left="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#12000000"/>
            <corners android:bottomLeftRadius="4dp" android:bottomRightRadius="4dp" android:topRightRadius="4dp"/>
        </shape>
    </item>

    <item android:right="2dp">
        <rotate
            android:fromDegrees="-45"
            android:pivotX="0%"
            android:pivotY="0%"
            android:toDegrees="0">
            <shape android:shape="rectangle" >
                <solid android:color="#12000000"/>
            </shape>
        </rotate>
    </item>

    <item android:left="1dp" android:right="2dp">
        <rotate
            android:fromDegrees="-45"
            android:pivotX="0%"
            android:pivotY="0%"
            android:toDegrees="0" >
            <shape android:shape="rectangle">

                <solid android:color="@color/colorBackgroundBubbleIn" />
            </shape>
        </rotate>
    </item>

    <item android:left="9dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/colorBackgroundBubbleIn" />
            <corners android:radius="4dp"/>
        </shape>
    </item>

</layer-list>