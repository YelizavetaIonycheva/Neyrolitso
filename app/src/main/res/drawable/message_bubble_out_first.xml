<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:right="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#12000000"/>
            <corners android:bottomLeftRadius="4dp" android:bottomRightRadius="4dp" android:topLeftRadius="4dp"/>
        </shape>
    </item>

    <item android:left="2dp">
        <rotate
            android:fromDegrees="45"
            android:pivotX="100%"
            android:pivotY="0%"
            android:toDegrees="0">
            <shape android:shape="rectangle">
                <solid android:color="#12000000"/>
            </shape>
        </rotate>
    </item>

    <item android:left="2dp" android:right="1dp">
        <rotate
            android:fromDegrees="45"
            android:pivotX="100%"
            android:pivotY="0%"
            android:toDegrees="0">
            <shape android:shape="rectangle">
                <solid android:color="@color/colorBackgroundBubbleOut" />
            </shape>
        </rotate>
    </item>

    <item android:left="1dp" android:right="9dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/colorBackgroundBubbleOut" />
            <corners android:radius="4dp"/>
        </shape>
    </item>

</layer-list>