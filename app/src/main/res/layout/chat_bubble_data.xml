<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!--  Files message  -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/fileList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:visibility="gone"/>

        <com.google.android.flexbox.FlexboxLayout
            android:id="@+id/container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:flexDirection="row_reverse"
            android:layout_gravity="end"
            app:flexWrap="wrap_reverse">

            <!--    Date message  -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lytStatusContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/date"
                    style="@style/textDateChat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="1dp"
                    android:gravity="bottom|end"
                    app:layout_constraintEnd_toStartOf="@id/statusImage"
                    app:layout_constraintBottom_toBottomOf="parent"
                    tools:text="17:10"/>
                <ImageView
                    android:id="@+id/statusImage"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:scaleType="fitCenter"
                    android:visibility="visible"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="@id/date"
                    android:layout_marginBottom="2dp"
                    tools:src="@drawable/ic_status_message_sending"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!--  Text message  -->
            <TextView
                android:id="@+id/messageText"
                style="@style/fontChatMessage"
                android:autoLink="web"
                android:linksClickable="true"
                android:textColorLink="@color/link_color"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="2dp"
                tools:text="Привет"/>

        </com.google.android.flexbox.FlexboxLayout>

