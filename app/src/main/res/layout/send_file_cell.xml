<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/sendFileHolder"
        android:layout_width="220dp"
        android:layout_height="40dp"
        android:background="@drawable/file_input_background"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:padding="4dp">

        <!-- Holder Icon -->
        <FrameLayout
            android:id="@+id/holder"
            android:layout_width="28dp"
            android:layout_height="28dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:visibility="visible">

            <RelativeLayout
                android:id="@+id/okSendHolder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/imageOk"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_centerInParent="true"
                    app:srcCompat="@drawable/ic_file"
                    app:tint="@android:color/white" />

            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/progressSendHolder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                tools:visibility="visible">

                <ProgressBar android:id="@+id/progress_bar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_centerInParent="true"
                    android:indeterminateDrawable="@drawable/spinner_ring"
                    android:indeterminateOnly="false"
                    android:indeterminateTint="@android:color/white"
                    android:progressDrawable="@drawable/circular_progress_bar"
                    android:max="100"/>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_centerInParent="true"
                    app:srcCompat="@drawable/ic_close"
                    app:tint="@android:color/white" />

            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/downloadSendHolder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_centerInParent="true"
                    app:srcCompat="@drawable/ic_download"
                    app:tint="@android:color/white" />

            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/errorSendHolder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_centerInParent="true"
                    app:srcCompat="@drawable/ic_close"
                    app:tint="@color/colorError" />

            </RelativeLayout>

        </FrameLayout>

        <!-- File name -->
        <FrameLayout
            android:id="@+id/fileNameLayout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintStart_toEndOf="@+id/holder"
            app:layout_constraintEnd_toStartOf="@+id/deleteSendHolder"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:visibility="invisible">

            <TextView
                android:id="@+id/nameFile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="start|center_vertical"
                android:ellipsize="middle"
                android:maxLines="1"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                tools:text="IMAGE.png"
                android:layout_marginStart="4dp"/>

        </FrameLayout>

        <!-- Progress voice playing -->
        <FrameLayout
            android:id="@+id/progressAudioLayout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintStart_toEndOf="@+id/holder"
            app:layout_constraintEnd_toStartOf="@+id/deleteSendHolder"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <ProgressBar
                    android:id="@+id/progressAudio"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    style="@android:style/Widget.Material.ProgressBar.Horizontal"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/currentTime"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.5"
                        android:layout_gravity="center_vertical"
                        android:gravity="start"/>

                    <TextView
                        android:id="@+id/durationTime"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.5"
                        android:layout_gravity="center_vertical"
                        android:gravity="end"/>
                </LinearLayout>
            </LinearLayout>


        </FrameLayout>

        <!-- Holder Delete Icon -->
        <RelativeLayout
            android:id="@+id/deleteSendHolder"
            android:layout_width="28dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:visibility="gone"
            tools:visibility="gone">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_centerInParent="true"
                app:srcCompat="@drawable/ic_delete"
                app:tint="@android:color/white" />

        </RelativeLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>